<!DOCTYPE html><html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gestor de Anime</title>
<style>
body { font-family: Arial; margin: 0; background: #0f172a; color: white; }
header { padding: 15px; background: #1e293b; text-align: center; font-size: 24px; }
.container { padding: 20px; max-width: 900px; margin: auto; }
input, select, button { padding: 8px; margin: 5px; border-radius: 8px; border: none; }
button { background: #3b82f6; color: white; cursor: pointer; }
.card { background: #1e293b; padding: 15px; border-radius: 12px; margin-bottom: 10px; }
.flex { display: flex; flex-wrap: wrap; gap: 10px; }
</style>
</head>
<body>
<header>🎬 Mi Gestor de Anime (GitHub Pages)</header><div class="container"><h2>Agregar Anime</h2>
<div class="flex">
<input id="nombre" placeholder="Nombre">
<input id="genero" placeholder="Género">
<select id="estado">
<option>Viendo</option>
<option>Terminado</option>
<option>Pendiente</option>
</select>
<input id="calificacion" placeholder="Calificación (1-10 o texto)">
<input id="capitulos" placeholder="Capítulos">
</div>
<button onclick="agregarAnime()">Agregar Anime</button><h2>Buscar / Filtrar</h2>
<input id="busqueda" placeholder="Buscar por nombre" oninput="mostrarAnimes()"><select id="filtroEstado" onchange="mostrarAnimes()">
<option value="">Todos</option>
<option value="Viendo">Viendo</option>
<option value="Terminado">Terminado</option>
<option value="Pendiente">Pendiente</option>
</select><h2>Lista de Animes</h2>
<div id="lista"></div></div><script>
// Cargar desde localStorage o usar datos iniciales
let animes = JSON.parse(localStorage.getItem("animes")) || [
    { nombre: "Toradora", genero: "Romance", estado: "Terminado", calificacion: "9", capitulos: 25 },
    { nombre: "Re:Zero", genero: "Isekai", estado: "Viendo", calificacion: "8", capitulos: 50 }
];

function guardarDatos() {
    localStorage.setItem("animes", JSON.stringify(animes));
}

function agregarAnime() {
    const nombre = document.getElementById("nombre").value;
    const genero = document.getElementById("genero").value;
    const estado = document.getElementById("estado").value;
    const calificacion = document.getElementById("calificacion").value;
    const capitulos = document.getElementById("capitulos").value;

    if(nombre === "") return alert("Ingresa un nombre");

    animes.push({ nombre, genero, estado, calificacion, capitulos });
    guardarDatos();
    mostrarAnimes();
}

function eliminarAnime(index) {
    animes.splice(index, 1);
    guardarDatos();
    mostrarAnimes();
}

function mostrarAnimes() {
    const lista = document.getElementById("lista");
    const filtro = document.getElementById("busqueda").value.toLowerCase();
    const estadoFiltro = document.getElementById("filtroEstado").value;

    lista.innerHTML = "";

    animes
    .filter(a => a.nombre.toLowerCase().includes(filtro))
    .filter(a => estadoFiltro === "" || a.estado === estadoFiltro)
    .forEach((anime, index) => {
        lista.innerHTML += `
        <div class="card">
            <h3>${anime.nombre}</h3>
            <p><b>Género:</b> ${anime.genero}</p>
            <p><b>Estado:</b> ${anime.estado}</p>
            <p><b>Capítulos:</b> ${anime.capitulos}</p>
            <p><b>Calificación:</b> ${anime.calificacion}</p>
            <button onclick="eliminarAnime(${index})">Eliminar</button>
        </div>`;
    });
}

mostrarAnimes();
</script></body>
</html>
